# MetaSift sandbox VPS — .env template
#
# Place at /opt/metasift/.env on the VPS. After editing:
#   sudo chown metasift:metasift /opt/metasift/.env
#   sudo chmod 600 /opt/metasift/.env
#   sudo systemctl restart metasift-api.service
#
# DO NOT commit a real, filled-out version of this file. The repo's root
# .env is gitignored; this template lives under deploy/sandbox/ purely as
# a reference shape. The deploy/sandbox/README.md runbook explains how to
# fill each field on the VPS.

# ─── OpenMetadata ────────────────────────────────────────────────
# OM is bound to 127.0.0.1 only on the VPS (docker-compose.sandbox.yml).
# The FastAPI app reaches it through the loopback interface — no Docker
# network bridging needed since both run on the host.
OPENMETADATA_HOST=http://127.0.0.1:8585
OPENMETADATA_API=http://127.0.0.1:8585/api
OPENMETADATA_JWT_TOKEN=

# AI SDK / MCP client — same OM endpoint, same token.
AI_SDK_HOST=http://127.0.0.1:8585
AI_SDK_TOKEN=

# ─── LLM provider (BYOK only) ────────────────────────────────────
# Sandbox is pure BYO-key per the locked decisions in
# SANDBOX_PHASES.md. Every visitor's chat / scan request carries its own
# X-OpenRouter-Key header; the FastAPI middleware reads that header and
# scopes the credential to the request via a ContextVar (Phase 1.4).
#
# Therefore: leave OPENROUTER_API_KEY blank. The §1.5 fallback / daily
# call counter were intentionally dropped — if a request lands without
# a header in sandbox mode, /chat/stream 402s with `byo_key_required`
# and the React app surfaces the BYO-key modal.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing — kept for local-dev parity and as a reference. None of
# these matter in sandbox without a backing key (the visitor's BYO key
# uses whatever model was set client-side via the chat-area picker).
MODEL_TOOLCALL=meta-llama/llama-3.3-70b-instruct:free
MODEL_DESCRIPTION=meta-llama/llama-3.3-70b-instruct:free
MODEL_CLASSIFICATION=meta-llama/llama-3.3-70b-instruct:free
MODEL_STALE_CHECK=meta-llama/llama-3.3-70b-instruct:free
MODEL_SCORING=meta-llama/llama-3.3-70b-instruct:free
MODEL_REASONING=meta-llama/llama-3.3-70b-instruct:free

# ─── App settings ────────────────────────────────────────────────
# APP_ENV / LOG_LEVEL / SANDBOX_MODE / SERVE_STATIC / API_HOST are all
# set authoritatively in metasift-api.service via Environment= directives
# so a bad edit here can't silently downgrade prod to debug logging or
# unset SANDBOX_MODE. They are intentionally absent below.
STREAMLIT_SERVER_PORT=8501

# ─── Optional ────────────────────────────────────────────────────
# CORS_ORIGINS=https://sandbox.metasift.org
# SQLITE_PATH=/opt/metasift/metasift.sqlite
