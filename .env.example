# ─── OpenMetadata ────────────────────────────────────────────────
# Local docker-compose stack defaults
OPENMETADATA_HOST=http://localhost:8585
OPENMETADATA_API=http://localhost:8585/api
OPENMETADATA_JWT_TOKEN=

# For the AI SDK / MCP client
AI_SDK_HOST=http://localhost:8585
AI_SDK_TOKEN=

# ─── LLM providers (Google Gemini is primary) ────────────────────
# Get a free key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Fallback / task-specific routing
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Model routing per task type ─────────────────────────────────
MODEL_TOOLCALL=gemini-2.5-flash
MODEL_DESCRIPTION=gemini-2.5-flash
MODEL_CLASSIFICATION=gemini-2.5-flash
MODEL_STALE_CHECK=gemini-2.5-flash
MODEL_SCORING=gemini-2.5-flash
MODEL_REASONING=gemini-2.5-flash

# ─── App settings ────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
STREAMLIT_SERVER_PORT=8501
