# ─── OpenMetadata ────────────────────────────────────────────────
# Local docker-compose stack defaults
OPENMETADATA_HOST=http://localhost:8585
OPENMETADATA_API=http://localhost:8585/api
OPENMETADATA_JWT_TOKEN=

# For the AI SDK / MCP client
AI_SDK_HOST=http://localhost:8585
AI_SDK_TOKEN=

# ─── LLM provider (OpenRouter) ───────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Model routing per task type ─────────────────────────────────
# Browse free models at https://openrouter.ai/models?pricing=free
MODEL_TOOLCALL=meta-llama/llama-3.3-70b-instruct:free
MODEL_DESCRIPTION=meta-llama/llama-3.3-70b-instruct:free
MODEL_CLASSIFICATION=meta-llama/llama-3.3-70b-instruct:free
MODEL_STALE_CHECK=meta-llama/llama-3.3-70b-instruct:free
MODEL_SCORING=meta-llama/llama-3.3-70b-instruct:free
MODEL_REASONING=meta-llama/llama-3.3-70b-instruct:free

# ─── App settings ────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
STREAMLIT_SERVER_PORT=8501
